NODE_ENV=development
TRUST_PROXY=0
COOKIE_SECURE=0
APP_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_DATA_ROOT=

SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY
SUPABASE_BUCKET=trazo-tutorials
SUPABASE_APP_SNAPSHOT_OBJECT=_system/app-state-v1.json
APP_SNAPSHOT_SAVE_DEBOUNCE_MS=3000
SUPABASE_AUTH_SNAPSHOT_OBJECT=_system/auth-state-v1.json
AUTH_SNAPSHOT_SAVE_DEBOUNCE_MS=1500
AUTO_CLOUD_SYNC_READ_MS=1000
CLOUD_MEDIA_TRANSFER_MAX_BYTES=104857600
MAX_UPLOAD_BYTES=5368709120

# Opcional (Google Drive OAuth existente en el proyecto)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
